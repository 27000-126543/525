<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ecommerce.platform.product.mapper.ProductSpuMapper">

    <resultMap id="spuResultMap" type="com.ecommerce.platform.product.entity.ProductSpu">
        <id column="id" property="id"/>
        <result column="spu_code" property="spuCode"/>
        <result column="spu_name" property="spuName"/>
        <result column="sub_title" property="subTitle"/>
        <result column="category_id" property="categoryId"/>
        <result column="brand_id" property="brandId"/>
        <result column="description" property="description"/>
        <result column="main_image" property="mainImage"/>
        <result column="images" property="images"/>
        <result column="price" property="price"/>
        <result column="original_price" property="originalPrice"/>
        <result column="sales" property="sales"/>
        <result column="status" property="status"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="unit" property="unit"/>
        <result column="weight" property="weight"/>
        <result column="is_new" property="isNew"/>
        <result column="is_hot" property="isHot"/>
        <result column="is_recommend" property="isRecommend"/>
        <result column="spec_template" property="specTemplate"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
        <result column="tenant_id" property="tenantId"/>
    </resultMap>

    <select id="selectSpuPage" resultMap="spuResultMap">
        SELECT * FROM product_spu
        <where>
            deleted = 0
            <if test="spu.spuName != null and spu.spuName != ''">
                AND spu_name LIKE CONCAT('%', #{spu.spuName}, '%')
            </if>
            <if test="spu.status != null">
                AND status = #{spu.status}
            </if>
            <if test="spu.categoryId != null">
                AND category_id = #{spu.categoryId}
            </if>
            <if test="spu.isHot != null">
                AND is_hot = #{spu.isHot}
            </if>
        </where>
        ORDER BY sort_order DESC, create_time DESC
    </select>

    <select id="selectHotProducts" resultMap="spuResultMap">
        SELECT * FROM product_spu
        WHERE deleted = 0 AND status = 1 AND is_hot = 1
        ORDER BY sales DESC, sort_order DESC
        LIMIT #{limit}
    </select>

    <select id="selectRecommendProducts" resultMap="spuResultMap">
        SELECT * FROM product_spu
        WHERE deleted = 0 AND status = 1 AND is_recommend = 1
        ORDER BY sort_order DESC, create_time DESC
        LIMIT #{limit}
    </select>
</mapper>
